{
    "compilerOptions": {
        "target": "ES5",
        "module": "ES6",
        "lib": ["ES2020", "DOM"],
        "moduleResolution": "node",
        "declaration": true,
        "declarationMap": true,
        "inlineSourceMap": false,
        "noEmitOnError": true,
        "noImplicitAny": true,
        "removeComments": true,
        "sourceMap": true,
        "strict": true
    },
    "include": ["*.ts"]
}
