{
    "compilerOptions": {
        "target": "ES5",
        "module": "ES2020",
        "lib": ["ES2020", "DOM", "WebWorker"],
        "moduleResolution": "node",
        "declaration": false,
        "declarationMap": false,
        "inlineSourceMap": false,
        "noEmitOnError": true,
        "noImplicitAny": true,
        "removeComments": true,
        "sourceMap": true,
        "strict": true
    },
    "include": ["*.ts"]
}
