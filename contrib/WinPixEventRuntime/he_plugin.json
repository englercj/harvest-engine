{
    "id": "WinPixEventRuntime",
    "name": "WinPixEventRuntime",
    "description": "Allows applications to be instrumented with marker events, for use with Microsoft PIX.",
    "version": "1.0.210818001",

    "author": "Microsoft",
    "license": "SEE LICENSE IN license.txt",
    "tags": [],

    "install": {
        "nuget": "WinPixEventRuntime#1.0.210818001",
        "valid_systems": ["windows"]
    },

    "modules": [
        {
            "name": "WinPixEventRuntime",
            "type": "shared",
            "group": "engine/contrib",
            "public_includedirs": ["Include/WinPixEventRuntime"],
            "variants": [
                {
                    "conditions": ["system:windows", "architecture:x86_64"],
                    "public_dependson": ["file:bin/x64/WinPixEventRuntime.lib"],
                    "post_build_commands": ["{COPYFILE} %{he.get_plugin('WinPixEventRuntime')._install_dir}/bin/x64/WinPixEventRuntime.dll %{cfg.targetdir}"]
                },
                {
                    "conditions": ["system:windows", "architecture:ARM64"],
                    "public_dependson": ["file:bin/ARM64/WinPixEventRuntime.lib"],
                    "post_build_commands": ["{COPYFILE} %{he.get_plugin('WinPixEventRuntime')._install_dir}/bin/ARM64/WinPixEventRuntime.dll %{cfg.targetdir}"]
                }
            ]
        }
    ]
}
