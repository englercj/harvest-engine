{
    "id": "he.rhi",
    "name": "Harvest RHI",
    "description": "Provides abstractions for low level rendering APIs.",
    "version": "1.0.0",

    "author": "Chad Engler <englercj@live.com>",
    "license": "UNLICENSED",
    "tags": [],

    "install": { "exec": "shaderc.lua" },

    "modules": [
        {
            "name": "he_rhi",
            "type": "static",
            "group": "engine/libs",
            "files": ["include/**", "src/**"],
            "public_dependson": ["he_core", "he_math"],
            "public_includedirs": ["include"],
            "private_includedirs": ["src"],
            "variants": [
                {
                    "conditions": ["system:windows"],
                    "public_dependson": ["WinPixEventRuntime"]
                }
            ]
        },
        {
            "name": "he_shaderc",
            "type": "console_app",
            "group": "engine/tools",
            "files": ["compiler/**"],
            "private_dependson": ["he_core", "slang"],
            "private_dependson_include": ["he_rhi"]
        }
    ]
}
