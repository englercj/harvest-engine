{
    "id": "he.window",
    "name": "Harvest Windowing",
    "description": "Provides windowing and input utilities for creating windowed applications.",
    "version": "1.0.0",

    "author": "Chad Engler <englercj@live.com>",
    "license": "",
    "tags": [],

    "modules": [
        {
            "name": "he_window",
            "type": "static",
            "group": "engine",
            "files": ["include/**", "src/**"],
            "public_dependson": ["he_core", "he_math"],
            "public_includedirs": ["include"],
            "private_includedirs": ["src"],
            "variants": [
                {
                    "filters": ["system:linux"],
                    "public_dependson": ["system:dl"]
                }
            ]
        },
        {
            "name": "he_window_test_app",
            "type": "windowed_app",
            "group": "tests",
            "files": ["test_app/**"],
            "private_dependson": ["he_core", "he_window"]
        }
    ]
}
