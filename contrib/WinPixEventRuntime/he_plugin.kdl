// Copyright Chad Engler

// WinPixEventRuntime - allows applications to be instrumented with marker events, for use with Microsoft PIX.
// https://devblogs.microsoft.com/pix/winpixeventruntime/
plugin microsoft.WinPixEventRuntime version="1.0.230302001" license="SEE LICENSE IN license.txt" {
    authors { "Microsoft" }

    install {
        when system=windows {
            fetch nuget package=WinPixEventRuntime version="${plugin.version}"
        }
    }

    module WinPixEventRuntime kind=lib_shared group="engine/contrib" {
        public {
            include_dirs { "${plugin.install_dir}/Include/WinPixEventRuntime" }
        }

        when system=windows arch=x86_64 {
            files {
                "${plugin.install_dir}/bin/x64/WinPixEventRuntime.dll" action=copy
            }
            public {
                dependencies { "${plugin.install_dir}/bin/x64/WinPixEventRuntime.lib" kind=file }
            }
        }

        when system=windows arch=arm64 {
            files {
                "${plugin.install_dir}/bin/ARM64/WinPixEventRuntime.dll" action=copy
            }
            public {
                dependencies { "${plugin.install_dir}/bin/ARM64/WinPixEventRuntime.lib" kind=file }
            }
        }
    }
}
