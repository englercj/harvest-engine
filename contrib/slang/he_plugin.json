{
    "id": "nvidia.slang",
    "name": "slang",
    "description": "Slang is a shading language that makes it easier to build and maintain large shader codebases in a modular and extensible fashion.",
    "version": "0.19.6",

    "author": "Carnegie Mellon University and NVIDIA Corporation",
    "license": "MIT",
    "tags": [],

    "install": {
        "archive": {
            "linux": "https://github.com/shader-slang/slang/releases/download/v0.19.6/slang-0.19.6-linux-x86_64.zip",
            "windows": "https://github.com/shader-slang/slang/releases/download/v0.19.6/slang-0.19.6-win64.zip"
        },
        "valid_systems": ["linux", "windows"]
    },

    "modules": [
        {
            "name": "slang",
            "type": "shared",
            "group": "engine/contrib",
            "public_includedirs": ["."],
            "variants": [
                {
                    "conditions": ["system:windows", "architecture:x86_64"],
                    "public_dependson": ["file:bin/windows-x64/release/slang.lib"],
                    "post_build_commands": [
                        "{COPYFILE} %{he.get_plugin('nvidia.slang')._install_dir}/bin/windows-x64/release/gfx.dll %{cfg.targetdir}",
                        "{COPYFILE} %{he.get_plugin('nvidia.slang')._install_dir}/bin/windows-x64/release/slang.dll %{cfg.targetdir}",
                        "{COPYFILE} %{he.get_plugin('nvidia.slang')._install_dir}/bin/windows-x64/release/slang-glslang.dll %{cfg.targetdir}",
                        "{COPYFILE} %{he.get_plugin('nvidia.slang')._install_dir}/bin/windows-x64/release/gfx.dll %{cfg.targetdir}"
                    ]
                }
            ]
        }
    ]
}
